# ── OpenC2 v1.0 — Variables de Entorno ───────────────────────────────────────
# Copia este archivo como .env y ajusta los valores antes de iniciar el servidor

C2_HOST=0.0.0.0
C2_PORT=8000
C2_DNS_PORT=15353
C2_LOG_LEVEL=INFO

# Claves RSA del servidor (se generan automáticamente si no existen)
SERVER_PRIVATE_KEY_PATH=./keys/server_priv.pem
SERVER_PUBLIC_KEY_PATH=./keys/server_pub.pem

# ── Autenticación ─────────────────────────────────────────────────────────────
# CAMBIAR por un token aleatorio en producción:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
OPERATOR_TOKEN=change-me-in-production

# JWT (dejar vacío = se genera aleatoriamente, expira al reiniciar)
JWT_SECRET=
JWT_EXPIRE_HOURS=24

DASHBOARD_ORIGIN=http://localhost:5173

# ── Solana Blockchain Anchoring ───────────────────────────────────────────────
SOLANA_ANCHOR=true
SOLANA_NETWORK=devnet                # devnet | testnet | mainnet-beta
SOLANA_WALLET_PATH=solana_wallet.json  # se genera automáticamente

# ── Canal DNS Covert ──────────────────────────────────────────────────────────
# Clave de 32 bytes en hex (64 caracteres) — dejar vacío para deshabilitar cifrado DNS
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
DNS_SHARED_KEY=

# ── Cola persistente ──────────────────────────────────────────────────────────
QUEUE_DB_PATH=pending_tasks.db

# ── Heartbeat del agente ──────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=10       # segundos base
HEARTBEAT_JITTER=0.3        # variación ±30% anti-fingerprint
